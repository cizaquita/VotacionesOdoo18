<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_partner_form_inherited" model="ir.ui.view">
        <field name="name">res.partner.form.inherited</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <sheet>
                <group>
                    <group string="Información del usuario">
                        <field name="id_number" string="Nro. Identificación"/>
                        <field name="is_candidate" 
                           invisible="is_student == True"
                           placeholder="Marque si es candidato"/>
                        <field name="is_student" 
                           invisible="is_candidate == True"
                           placeholder="Marque si es estudiante"/>
                        <field name="campus_id"/>
                        <field name="career"/>
                    </group>
                </group>
            </sheet>
        </field>
    </record>
</odoo>
