<odoo>
    <record id="view_voting_process_importer_wizard_form" model="ir.ui.view">
        <field name="name">uniacme_votes.voting_process_importer_wizard.form</field>
        <field name="model">uniacme_votes.voting_process_importer_wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Procesos de Votación" create="false" edit="false">                
                <group>
                
                    <group>
                        <h2>Cargar archivo</h2>
                        <field name="filename" invisible="1"/>
                        <field name="file" filename="filename" required="1"/>
                    </group>

                    <group>
                        <a href="/voting/download_template" role="button" class="btn btn-secondary" target="_blank">
                            Descargar plantilla de ejemplo
                        </a>
                    </group>
                </group>
                <footer>
                    <button string="Importar" type="object" name="import_voting_processes" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_voting_process_importer_wizard" model="ir.actions.act_window">
        <field name="name">Importar Procesos de Votación</field>
        <field name="res_model">uniacme_votes.voting_process_importer_wizard</field>
        <field name="path">voting-process-wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_voting_process_importer_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
